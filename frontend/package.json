{
  "name": "frontend",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --host 0.0.0.0",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "typecheck": "nuxt typecheck",
    "mobile:sync": "pnpm generate && pnpm exec cap sync",
    "dev:android": "pnpm generate && pnpm exec cap sync && pnpm exec cap run android",
    "mobile:ios": "pnpm exec cap open ios",
    "mobile:android": "pnpm exec cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
