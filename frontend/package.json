    "@nuxt/eslint": "^1.10.0",
    "@nuxt/fonts": "^0.12.1",
    "@nuxt/icon": "^2.1.0",
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/color-mode": "^4.0.1",
    "@nuxtjs/i18n": "^10.4.0",
    "@pinia/nuxt": "^0.5.5",
    "@tailwindcss/vite": "^4.1.17",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.0.0",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "^9.39.1",
    "lucide-vue-next": "^0.553.0",
    "nuxt": "^4.2.1",
    "pinia": "^2.2.0",
    "reka-ui": "^2.9.10",
    "shadcn-vue": "^2.7.4",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.1.17",
    "tw-animate-css": "^1.4.0",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.24",
    "vue-router": "^5.1.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "@iconify-json/lucide": "^1.2.113",
    "@iconify-json/uil": "^1.2.3",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^24.10.1",
    "@typescript-eslint/parser": "^8.61.0",
    "dotenv": "^17.4.2",
