# URL de base de l'API backend — cible du proxy de la route `/api/v1/**` (web/SSR).
API_URL=http://localhost:3333

# Base API publique utilisée par le client.
# Web : laisser vide pour utiliser le proxy même-origine `/api/v1`.
# Mobile (build statique Capacitor) : définir l'URL complète du backend, ex. https://api.example.com
# NUXT_PUBLIC_API_BASE=http://localhost:3333
