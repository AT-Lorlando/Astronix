<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ title || 'Admin' }}</title>
    <style>
      :root { color-scheme: dark; }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: ui-sans-serif, system-ui, -apple-system, sans-serif;
        background: #0c0f0d;
        color: #e6e6e6;
        line-height: 1.5;
      }
      a { color: #4ade80; }
      .wrap { max-width: 880px; margin: 0 auto; padding: 2rem 1.25rem 4rem; }
      header.bar {
        display: flex; align-items: center; justify-content: space-between;
        margin-bottom: 2rem; gap: 1rem;
      }
      header.bar h1 { font-size: 1.35rem; margin: 0; }
      .muted { color: #9ca3af; }
      table { width: 100%; border-collapse: collapse; }
      th, td { text-align: left; padding: 0.65rem 0.5rem; border-bottom: 1px solid #1f2937; vertical-align: top; }
      th { color: #9ca3af; font-weight: 600; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.04em; }
      tr.unread td { font-weight: 600; }
      .badge {
        display: inline-block; font-size: 0.7rem; font-weight: 700;
        background: #4ade80; color: #0c0f0d; border-radius: 999px; padding: 0.05rem 0.5rem;
      }
      .btn {
        display: inline-block; cursor: pointer; font: inherit; font-size: 0.85rem;
        background: #1f2937; color: #e6e6e6; border: 1px solid #374151;
        border-radius: 6px; padding: 0.4rem 0.8rem; text-decoration: none;
      }
      .btn:hover { background: #374151; }
      .btn-primary { background: #4ade80; color: #0c0f0d; border-color: #4ade80; }
      .btn-danger { background: transparent; color: #f87171; border-color: #7f1d1d; }
      .actions { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1.5rem; }
      form.inline { display: inline; margin: 0; }
      .field { margin-bottom: 1rem; }
      .field label { display: block; font-size: 0.85rem; color: #9ca3af; margin-bottom: 0.3rem; }
      .field input {
        width: 100%; padding: 0.55rem 0.7rem; border-radius: 6px;
        border: 1px solid #374151; background: #111827; color: #e6e6e6; font: inherit;
      }
      .alert { background: #7f1d1d33; border: 1px solid #7f1d1d; color: #fca5a5; padding: 0.6rem 0.8rem; border-radius: 6px; margin-bottom: 1rem; }
      .card { background: #111827; border: 1px solid #1f2937; border-radius: 8px; padding: 1.25rem; }
      .msg-body { white-space: pre-wrap; margin-top: 1rem; }
      dl { display: grid; grid-template-columns: max-content 1fr; gap: 0.35rem 1rem; margin: 0; }
      dt { color: #9ca3af; }
      dd { margin: 0; }
    </style>
  </head>
  <body>
    <main class="wrap">
      {{{ await $slots.main() }}}
    </main>
  </body>
</html>
